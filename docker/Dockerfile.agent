FROM golang:1.22-alpine AS sidecar-build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY pkg/ pkg/
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /sidecar ./cmd/sidecar/

FROM node:22-slim

ARG HOST_UID=1000
ARG HOST_GID=1000

ENV TERM=xterm-256color

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        git \
        python3 \
        python3-venv \
        ripgrep \
        tini \
    && npm install --global --no-audit --no-fund \
        @anthropic-ai/claude-code \
        @openai/codex \
    && npm cache clean --force \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /usr/local/bin/uv \
    && chmod 755 /usr/local/bin/uv

RUN if getent group "${HOST_GID}" > /dev/null; then \
      EXISTING_GROUP="$(getent group "${HOST_GID}" | cut -d: -f1)"; \
      if [ "${EXISTING_GROUP}" != "agent" ]; then \
        groupmod -n agent "${EXISTING_GROUP}"; \
      fi; \
    elif getent group agent > /dev/null; then \
      groupmod --gid "${HOST_GID}" agent; \
    else \
      groupadd -g "${HOST_GID}" agent; \
    fi \
    && if getent passwd "${HOST_UID}" > /dev/null; then \
      EXISTING_USER="$(getent passwd "${HOST_UID}" | cut -d: -f1)"; \
      if [ "${EXISTING_USER}" != "agent" ]; then \
        usermod -l agent -d /home/agent -m -g "${HOST_GID}" "${EXISTING_USER}"; \
      else \
        usermod --gid "${HOST_GID}" agent; \
      fi; \
    elif id agent > /dev/null 2>&1; then \
      usermod --uid "${HOST_UID}" --gid "${HOST_GID}" agent; \
    else \
      useradd --uid "${HOST_UID}" --gid "${HOST_GID}" --create-home --shell /bin/bash agent; \
    fi

RUN mkdir -p /home/agent/.claude /home/agent/.codex /workspace \
    && chown -R agent:agent /home/agent /workspace \
    && git init /workspace

USER agent

COPY --from=sidecar-build /sidecar /usr/local/bin/agentruntime-sidecar

EXPOSE 9090

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/usr/local/bin/agentruntime-sidecar"]
